# Nutri-Guardian Pro Configuration
# Copy this file to .env.local and fill in the values from your Firebase Project Console.

# === FRONTEND FIREBASE CONFIG ===
# You can find these in Firebase Console -> Project Settings -> General -> Your apps
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""

# Emulator Toggle (Set to true to use local emulators)
VITE_USE_EMULATOR="false"

# === FIREBASE FUNCTIONS ENV DEPLOYMENT ===
# Do not put GEMINI_API_KEY here for production. 
# Production functions should use Firebase Secret Manager.
# But for local proxying the vite dev server, we use this:
GEMINI_API_KEY="INSERT_YOUR_GOOGLE_AI_STUDIO_KEY"

# The production URL for CORS (no trailing slash)
VITE_PROD_URL="https://your-project-id.web.app"
